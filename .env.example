# Airflow Configuration
# Generate a secure FERNET_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=temporary_fernet_key
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__WORKERS=2
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow

# Weather Data Enrichment
# Get a free API key at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# DuckDB Database Path (optional, defaults to duckdb/transport_analytics.duckdb)
# DUCKDB_PATH=duckdb/transport_analytics.duckdb

# Spark Configuration (optional)
# SPARK_APP_NAME=SmartPublicTransport
# JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64

# Project Paths (optional, auto-detected from repo root)
# PROJECT_ROOT=.
# RAW_DATA_DIR=data/raw
# PROCESSED_DATA_DIR=data/processed
